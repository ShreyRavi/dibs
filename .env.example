# Shared Supabase project (REDSA). All Dibs objects are `dibs_`-prefixed.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-REDSA-PROJECT.supabase.co
# anon key — shipped to the browser ONLY for the Realtime Broadcast websocket.
# It never reads/writes dibs_ tables (those go through route handlers).
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER ONLY. Bypasses RLS. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# HMAC secret for signing the per-device identity cookie. 32+ random bytes.
DIBS_COOKIE_SECRET=generate-with-openssl-rand-hex-32

# Public base URL (used for OG tags / absolute share links).
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Protects the TTL sweep cron (/api/sweep). Vercel Cron sends it as a Bearer
# token automatically when set. openssl rand -hex 32.
CRON_SECRET=generate-with-openssl-rand-hex-32

# Optional: distributed rate limiting via Upstash Redis (free tier works). When
# both are set, rate limits are shared across instances; otherwise in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
